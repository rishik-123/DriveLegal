# ─── DriveVerse Environment Configuration ───────────────────────
# Copy this file to .env and fill in your credentials.

# ─── App ─────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-this-in-production
DEBUG=true

# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/driveverse
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/driveverse

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT ─────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-change-this-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Google OAuth ────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ─── Google Gemini AI (Astra AI) ─────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ─── Google Maps ─────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ─── SMTP Email (OTP Delivery) ───────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=jashthakkar77
SMTP_PASSWORD=cuiegdqjaesgakcg
SMTP_SENDER=jashthakkar77@gmail.com

# ─── SMS OTP (MSG91 / Twilio) ────────────────────────────────────
SMS_PROVIDER=msg91
MSG91_API_KEY=
MSG91_TEMPLATE_ID=
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── DigiLocker ──────────────────────────────────────────────────
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=
DIGILOCKER_REDIRECT_URI=http://localhost:3000/dashboard/documents/callback

# ─── AES Encryption Key (32 chars) ───────────────────────────────
AES_ENCRYPTION_KEY=driveverse-aes-key-32bytes-long!

# ─── Firebase Cloud Messaging ────────────────────────────────────
FCM_SERVER_KEY=

# ─── Frontend ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
